e73f2e0", "הַיָּם כָּחֹל.": "5a478f92d1877c26", "יָרֹק": "9a8578dc611b7cfc", "הָעֵץ יָרֹק.": "b054199a58fa9da0", "רֹאשׁ": "85e2373641a00ddb", "כּוֹאֵב לִי הָרֹאשׁ.": "ed9f629468fbad7d", "לֶחֶם": "64e54dd5d0bdec26", "אֲנִי קוֹנֶה לֶחֶם.": "0303d9910550940e", "חָלָב": "d4d0e93977f1662a", "אֲנִי שׁוֹתֶה חָלָב.": "689f7f58945532bc", "בֵּיצָה": "cf0284e0f5f374db", "אֲנִי אוֹכֵל בֵּיצָה.": "2b7b8d9d1cac513b", "שׁוֹתֶה": "07f6e780bcfca597", "אֲנִי שׁוֹתֶה קָפֶה.": "73a325152713305d", "מְדַבֵּר": "f835abd42fc58e25", "אֲנִי מְדַבֵּר עִבְרִית.": "7dfb50bcea28c436", "קוֹרֵא": "55b3ad375771546a", "אֲנִי קוֹרֵא עִתּוֹן.": "e57713047da306be", "מָה": "1691cb25fa786de0", "מָה זֶה?": "645c5378441e2599", "אֵיפֹה": "9a10b1f7430b659e", "אֵיפֹה אַתָּה?": "1c7c85bd2fe33956", "מָתַי": "9f02a4e95b668d7d", "מָתַי אַתָּה בָּא?": "a505efb6481258ee", "שָׁלוֹם, אֲנִי רוֹצֶה קָפֶה, בְּבַקָּשָׁה.": "5f445bf099113281", "גָּדוֹל אוֹ קָטָן?": "85428c252fdcf679", "גָּדוֹל, תּוֹדָה.": "d985de8ab75dc8db", "עוֹד מַשֶּׁהוּ?": "785770a755748034", "לֹא, זֶה הַכֹּל.": "6b197adcc6b97075", "הֵיי, מָה נִשְׁמָע?": "871a0b1399e6a3af", "הַכֹּל טוֹב, תּוֹדָה. וְאַתָּה?": "46bfadfbc506cf6f", "גַּם טוֹב. בָּא לְךָ לֶאֱכֹל מַשֶּׁהוּ?": "25afb2b0954db02e", "בְּטַח, אֲנִי רָעֵב.": "78086828d79f1b65", "תֵּל אָבִיב הִיא עִיר גְּדוֹלָה בְּיִשְׂרָאֵל.": "18b8df5483006c57", "הַרְבֵּה אֲנָשִׁים גָּרִים וְעוֹבְדִים שָׁם.": "678b93385c8eff4c", "בָּעִיר יֵשׁ חוֹף יָם יָפֶה וְהַרְבֵּה בָּתֵּי קָפֶה.": "a57ff32eed133fd9", "יָשָׁר וְאָז יְמִינָה.": "29e87c62d120066e", "זֶה רָחוֹק?": "96eec6ca6db8c133", "לֹא, חָמֵשׁ דַּקּוֹת בְּרֶגֶל.": "d4bd987e5b45fd6e", "תּוֹדָה רַבָּה!": "321e152762ca201c", "הַלּוֹ, מָה נִשְׁמָע?": "18c1ad269b0e0fc3", "בְּסֵדֶר, תּוֹדָה. אַתָּה פָּנוּי מָחָר?": "0f37bb00a47fde9a", "כֵּן, בָּעֶרֶב.": "656883d99568b4d6", "יוֹפִי, נִפָּגֵשׁ בְּשֶׁבַע.": "1e72a3d883fd6dc5", "טוֹב, לְהִתְרָאוֹת!": "063ecd3f2d31f73b", "בְּיִשְׂרָאֵל יֵשׁ קַיִץ חַם וְאָרֹךְ.": "f025cfafd63da783", "בַּחֹרֶף יוֹרֵד גֶּשֶׁם, אֲבָל לֹא הַרְבֵּה.": "6e6cef2cc6a3d8f0", "הָאָבִיב נָעִים וְיָרֹק.": "bf90467083af76c1", "הַרְבֵּה אֲנָשִׁים אוֹהֲבִים אֶת הַיָּם בַּקַּיִץ.": "a98df028117e5109", "בְּיִשְׂרָאֵל אוֹהֲבִים לֶאֱכֹל חוּמוּס.": "b71028a499d7cf41", "אֶפְשָׁר לִמְצֹא אוֹתוֹ כִּמְעַט בְּכָל מָקוֹם.": "101a2c2e8ae4fd5e", "הַרְבֵּה אֲנָשִׁים אוֹכְלִים אוֹתוֹ עִם פִּיתָה.": "3cd3fcfc2c2bb788", "זֶה טָעִים, זוֹל וּבָרִיא.": "4a7fc38f603c043f", "שָׁלוֹם, אֲנִי דָּוִד.": "75dd3264fbf68c9a", "נָעִים מְאֹד, אֲנִי שָׂרָה.": "925580692e06a87b", "מֵאַיִן אַתְּ?": "7decfa47d96f72f2", "אֲנִי מִתֵּל אָבִיב. וְאַתָּה?": "0adae6715b2a7d7b", "אֲנִי מִירוּשָׁלַיִם.": "4fcbf35686be3153", "שָׁלוֹם, מָה תִּרְצוּ לֶאֱכֹל?": "55eeeb93f9829582", "אֲנִי רוֹצֶה סָלָט, בְּבַקָּשָׁה.": "2ba904bc2325f13c", "וְלִשְׁתּוֹת?": "b141df75d01825af", "מַיִם, תּוֹדָה.": "7657bdcc5f2fc054", "בְּבַקָּשָׁה, רֶגַע אֶחָד.": "df1393e24ba675f9", "בְּעִבְרִית, הַשָּׁבוּעַ מַתְחִיל בְּיוֹם רִאשׁוֹן.": "80f091d55471eb53", "רֹב הָאֲנָשִׁים עוֹבְדִים עַד יוֹם חֲמִישִׁי.": "f9032624ddd70b54", "יוֹם שִׁשִּׁי וְשַׁבָּת הֵם יְמֵי מְנוּחָה.": "938798281948ad42", "בְּשַׁבָּת, מִשְׁפָּחוֹת רַבּוֹת אוֹכְלוֹת יַחַד.": "34db8f64aed73a66", "יֵשׁ לָכֶם חָלָב?": "230b7fcd51eaa49c", "כֵּן, בַּמְּקָרֵר.": "e25ee064fdc613bb", "וְגַם לֶחֶם, בְּבַקָּשָׁה.": "5927a135cc60ad1e", "בְּבַקָּשָׁה. עוֹד מַשֶּׁהוּ?": "64e6e1dd00bd8938", "לֹא, כַּמָּה זֶה עוֹלֶה?": "757ec0ba18c24ba1", "סְלִיחָה, מָה הַשָּׁעָה?": "b0c420dbaeb08dca", "עַכְשָׁו שָׁלוֹשׁ.": "77c84ba9f4e77bca", "תּוֹדָה! אֲנִי מְאַחֵר.": "1778e9c0897682d3", "בְּבַקָּשָׁה, יוֹם טוֹב.": "75ac5f98118edf7f", "שָׁלוֹם, קוֹרְאִים לִי מַיָּה.": "a03cba89d3f31a41", "אֲנִי גָּרָה בְּתֵל אָבִיב עִם הַמִּשְׁפָּחָה שֶׁלִּי.": "726411492786da3a", "אֲנִי לוֹמֶדֶת בָּאוּנִיבֶרְסִיטָה.": "36a528aa6370202d", "בַּזְּמַן הַפָּנוּי אֲנִי אוֹהֶבֶת לִקְרֹא.": "1a1dfffdc8fdc3ad"}}